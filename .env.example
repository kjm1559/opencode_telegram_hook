# Telegram Plugin Configuration

# Required - Your Telegram Bot Token
# Get from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_HERE"

# Optional - Your Telegram Chat ID (for direct messages)
# Get from: https://t.me/userinfobot
TELEGRAM_CHAT_ID="YOUR_CHAT_ID"

# Optional - Allowed chat IDs (comma-separated, for security)
ALLOWED_CHAT_IDS=""

# Optional - Max events per summary (default: 100)
MAX_EVENTS_PER_SUMMARY=100

# Optional - Projects configuration (JSON array)
# Example: PROJECTS='[{"display_name":"myproject","directory":"/home/mj/project/myproject"}]'
PROJECTS=""
